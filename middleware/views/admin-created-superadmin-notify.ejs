<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>New Admin Account Created</title>
</head>

<body style="margin:0;padding:0;background:#f4f7f5;font-family:Arial,sans-serif;">

  <div style="max-width:600px;margin:40px auto;background:white;border-radius:12px;overflow:hidden;border:1px solid #dcefe3;">

    <div style="background:linear-gradient(135deg,#1b4332,#2d6a4f);padding:30px;text-align:center;">
      <h1 style="color:white;margin:0;">🌱 AgroSense</h1>
      <p style="color:#d8f3dc;margin-top:10px;">
        Smart Farming Platform
      </p>
    </div>

    <div style="padding:40px 30px;">
      <h2 style="color:#1b4332;">
        Admin Account Created ✅
      </h2>

      <p style="color:#444;line-height:1.7;">
        Hi <strong><%= superAdminName %></strong>, this is a confirmation that you successfully created a new admin account on AgroSense.
      </p>

      <div style="background:#f0f7f4;border:1px solid #b7dfc9;border-radius:8px;padding:20px;margin:24px 0;">
        <p style="margin:0 0 10px;color:#444;"><strong>Name:</strong> <span style="color:#1b4332;"><%= newAdminName %></span></p>
        <p style="margin:0 0 10px;color:#444;"><strong>Email:</strong> <span style="color:#1b4332;"><%= newAdminEmail %></span></p>
        <p style="margin:0;color:#444;"><strong>Created:</strong> <%= createdAt %></p>
      </div>

      <p style="color:#444;line-height:1.7;">
        A notification has been sent to <strong><%= newAdminEmail %></strong> with their login details.
      </p>

      <p style="color:#888;font-size:13px;line-height:1.6;">
        If you did not perform this action, please contact your platform administrator immediately.
      </p>
    </div>

    <div style="background:#f0f7f4;padding:20px;text-align:center;font-size:13px;color:#666;">
      AgroSense © 2026 • Smart Farming Platform
    </div>

    <p style="color:#888;font-size:12px;text-align:center;">
      If this email landed in spam, please mark it as "Not Spam" to receive future updates.
    </p>
  </div>

</body>
</html>
