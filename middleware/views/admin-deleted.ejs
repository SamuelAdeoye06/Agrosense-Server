<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Your AgroSense Admin Account Has Been Removed</title>
</head>

<body style="margin:0;padding:0;background:#f4f7f5;font-family:Arial,sans-serif;">

  <div style="max-width:600px;margin:40px auto;background:white;border-radius:12px;overflow:hidden;border:1px solid #dcefe3;">

    <div style="background:linear-gradient(135deg,#7f1d1d,#991b1b);padding:30px;text-align:center;">
      <h1 style="color:white;margin:0;">🌱 AgroSense</h1>
      <p style="color:#fca5a5;margin-top:10px;">Smart Farming Platform</p>
    </div>

    <div style="padding:40px 30px;">
      <h2 style="color:#991b1b;">Your Admin Account Has Been Removed</h2>

      <p style="color:#444;line-height:1.7;">
        Hi <strong><%= name %></strong>,
      </p>

      <p style="color:#444;line-height:1.7;">
        Your AgroSense admin account associated with <strong><%= email %></strong> has been permanently removed from the platform by the Super Administrator.
      </p>

      <div style="background:#fff5f5;border:1px solid #fca5a5;border-radius:8px;padding:16px;margin:24px 0;">
        <p style="margin:0 0 8px;color:#991b1b;font-size:13px;">
          <strong>Account:</strong> <%= email %>
        </p>
        <p style="margin:0;color:#991b1b;font-size:13px;">
          <strong>Removed on:</strong> <%= actionDate %>
        </p>
      </div>

      <p style="color:#444;line-height:1.7;">
        You no longer have access to the AgroSense admin dashboard. If you believe this was done in error, please contact the Super Administrator directly.
      </p>
    </div>

    <div style="background:#f0f7f4;padding:20px;text-align:center;font-size:13px;color:#666;">
      AgroSense © 2026 • Smart Farming Platform
    </div>
    <p style="color:#888;font-size:12px;text-align:center;">
      If this email landed in spam, please mark it as "Not Spam" to receive future updates.
    </p>
  </div>

</body>
</html>