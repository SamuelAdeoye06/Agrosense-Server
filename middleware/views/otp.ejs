<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Your AgroSense OTP</title>
</head>
<body style="margin:0;padding:0;background:#f4f7f5;font-family:Arial,sans-serif;">
  <div style="max-width:600px;margin:40px auto;background:white;border-radius:12px;overflow:hidden;border:1px solid #dcefe3;">

    <div style="background:linear-gradient(135deg,#1b4332,#2d6a4f);padding:30px;text-align:center;">
      <h1 style="color:white;margin:0;">🌱 AgroSense</h1>
      <p style="color:#d8f3dc;margin-top:10px;">Smart Farming Platform</p>
    </div>

    <div style="padding:40px 30px;text-align:center;">
      <h2 style="color:#1b4332;">
        <%= purpose === 'delete' ? 'Account Deletion OTP 🗑️' : 'Password Reset OTP 🔐' %>
      </h2>

      <p style="color:#444;line-height:1.7;">
        Hi <strong><%= name %></strong>,
        <%= purpose === 'delete'
            ? 'You requested to permanently delete your AgroSense account. Use the OTP below to confirm.'
            : 'You requested a password reset. Use the OTP below to proceed.' %>
      </p>

      <div style="margin:30px auto;background:#f0f7f4;border:2px dashed #2d6a4f;border-radius:12px;padding:24px;max-width:240px;">
        <p style="margin:0;font-size:2.2rem;font-weight:900;letter-spacing:10px;color:#1b4332;">
          <%= otp %>
        </p>
      </div>

      <p style="color:#888;font-size:13px;margin-top:16px;">
        This OTP expires in <strong>10 minutes</strong>. Do not share it with anyone.
      </p>

      <% if (purpose === 'delete') { %>
        <div style="background:#fff5f5;border:1px solid #fca5a5;border-radius:8px;padding:14px;margin-top:24px;text-align:left;">
          <p style="margin:0;color:#991b1b;font-size:13px;">
            ⚠️ This action is <strong>permanent</strong>. All your data including saved dates and crop profiles will be lost.
          </p>
        </div>
      <% } %>

      <p style="color:#888;font-size:13px;margin-top:24px;">
        If you did not request this, ignore this email — your account is safe.
      </p>
    </div>

    <div style="background:#f0f7f4;padding:20px;text-align:center;font-size:13px;color:#666;">
      AgroSense © 2026 • Smart Farming Platform
    </div>
    <p style="color:#888;font-size:12px;text-align:center;">
      If this email landed in spam, please mark it as "Not Spam".
    </p>
  </div>
</body>
</html>